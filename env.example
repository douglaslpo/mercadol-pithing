# ===========================================
# CONFIGURAÇÕES GERAIS
# ===========================================
NODE_ENV=development
APP_VERSION=1.0.0

# ===========================================
# BANCO DE DADOS
# ===========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/mercadol_pithing
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=mercadol_pithing

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# APIS EXTERNAS - MERCADO LIVRE
# ===========================================
MELI_APP_ID=your_meli_app_id
MELI_CLIENT_SECRET=your_meli_client_secret
MELI_REDIRECT_URI=http://localhost:3001/api/auth/meli/callback
MELI_SITE_ID=MLB

# ===========================================
# APIS EXTERNAS - ALIBABA CLOUD IMAGE SEARCH
# ===========================================
ALIBABA_ACCESS_KEY_ID=your_alibaba_access_key
ALIBABA_ACCESS_KEY_SECRET=your_alibaba_secret
ALIBABA_REGION=cn-shanghai

# ===========================================
# APIS EXTERNAS - SHOPEE
# ===========================================
SHOPEE_PARTNER_ID=your_shopee_partner_id
SHOPEE_PARTNER_KEY=your_shopee_partner_key

# ===========================================
# APIS EXTERNAS - WISH
# ===========================================
WISH_CLIENT_ID=your_wish_client_id
WISH_CLIENT_SECRET=your_wish_client_secret

# ===========================================
# OBSERVABILIDADE
# ===========================================
OTEL_SERVICE_NAME=mercadol-pithing-api
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6832

# ===========================================
# FRONTEND
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=MercadoL Pithing

# ===========================================
# PORTA DA API
# ===========================================
API_PORT=3001